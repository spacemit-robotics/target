{
  "version": "1.0",
  "board": "k3",
  "product": "uav-ros",
  "description": "K3 UAV ROS2 build configuration",
  "enabled_packages": [
    "components/control/gimbal",
    "middleware/ros2/control/gimbal/",
    "application/ros2/uav"
  ],
  "enabled_package_options": {
    "components/control/gimbal": { "enabled_drivers": ["drv_udp_c12"] }
  },
  "options": {
    "parallel_jobs": 4,
    "auto_resolve_dependencies": true
  }
}
